PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enc_dev
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# AWS S3 (for avatar uploads — omit all to use local filesystem in dev)
# GUARDRAILS: Both AWS_ACCOUNT_ID and enc- bucket prefix are required.
# The app will refuse to connect if the account ID doesn't match or the
# bucket name doesn't start with "enc-".
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=423673304206
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=enc-uploads
CDN_URL=https://cdn.example.com
